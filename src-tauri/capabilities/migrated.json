{
  "identifier": "migrated",
  "description": "permissions that were migrated from v1",
  "local": true,
  "windows": [
    "main",
    "tag",
    "certificate-installer",
    "breakpoint-hit",
    "breakpoint",
    "diffing",
    "logging",
    "rewrite",
    "scripting",
    "sessions",
    "viewers",
    "filters"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    "dialog:allow-message",
    "dialog:allow-save",
    "dialog:allow-open",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:path:allow-resolve-directory"
  ]
}