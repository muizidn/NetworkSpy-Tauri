{
  "productName": "Network Spy",
  "version": "0.0.0",
  "identifier": "com.muiz.idn.tauri.dev",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,

    "windows": [
      {
        "title": "Network Spy",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "transparent": true,

        "titleBarStyle": "Transparent"
      }


    ],

    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^https://.*$"
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/muizidn/NetworkSpy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCOUMxMjgzNzA2MkI2NzAKUldSd3RtSndneEtjZTVKeE5ySklXM21Idnk1UFdpSkQ1N0JXNHZ1YXBNTW9vdFdXb0VOSVMyUlAK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}