APP_NAME="Network Spy (DEV)"
# APP_NAME="Network Spy (STAGING)"
# APP_NAME="Network Spy"

# PostHog Analytics (Provide these in your GitHub Secrets as well)
VITE_POSTHOG_KEY="your_posthog_project_api_key"
VITE_POSTHOG_HOST="https://app.posthog.com"

# Sentry Error Tracking (Provide these in your GitHub Secrets for production)
# You can use the same DSN for both if you want to track them in one project
VITE_SENTRY_DSN="your_sentry_frontend_dsn"
SENTRY_DSN="your_sentry_backend_dsn"
# Required for automatic source map uploads during build
SENTRY_AUTH_TOKEN="your_sentry_auth_token"
